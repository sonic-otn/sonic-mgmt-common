    deviation /oc-otdr:otdrs/oc-otdr:otdr/oc-otdr:scan-results/oc-otdr:result/oc-otdr:trace/oc-otdr:event/oc-otdr:event-id {
      deviate add {
        sonic-ext:field-name "event_id";
      }
    }

    deviation /oc-otdr:otdrs/oc-otdr:otdr/oc-otdr:scan-results/oc-otdr:result/oc-otdr:trace/oc-otdr:event/oc-otdr:type {
