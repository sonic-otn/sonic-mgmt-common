      }
    }

    deviation /oc-otdr:otdrs/oc-otdr:otdr/oc-otdr:scan-results/oc-otdr:result/oc-otdr:trace/oc-otdr:event {
      deviate add {
        sonic-ext:table-name "OTN_OTDR_EVENT";
